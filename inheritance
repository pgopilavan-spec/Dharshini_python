class Employee:
    def __init__(self, empid, name, salary):
        self.empid = empid
        self.name = name
        self.salary = salary
class Manager(Employee):
    def __init__(self, empid, name, salary, bonus):
        super().__init__(empid, name, salary)
        self.bonus = bonus
    def total_salary(self):
        print("Manager Salary:", self.salary + self.bonus)
class Supervisor(Employee):
    def __init__(self, empid, name, salary, allowance):
        super().__init__(empid, name, salary)
        self.allowance = allowance
    def total_salary(self):
        print("Supervisor Salary:", self.salary + self.allowance)
m = Manager(1, "Ravi", 50000, 10000)
m.total_salary()
s = Supervisor(2, "Kumar", 40000, 5000)
s.total_salary()
