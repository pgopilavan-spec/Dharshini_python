class Vehicle:
    def __init__(self, reg_no, fuel_type):
        self.reg_no = reg_no
        self.fuel_type = fuel_type
    def display(self):
        print("Registration No:", self.reg_no)
        print("Fuel Type:", self.fuel_type)
class Car(Vehicle):
    def __init__(self, reg_no, fuel_type, seats):
        super().__init__(reg_no, fuel_type)
        self.seats = seats
    def show(self):
        self.display()
        print("Seating Capacity:", self.seats)
class Truck(Vehicle):
    def __init__(self, reg_no, fuel_type, load):
        super().__init__(reg_no, fuel_type)
        self.load = load
    def show(self):
        self.display()
        print("Load Capacity:", self.load)
