class Shape:
    pass
class Circle(Shape):
    def __init__(self, r):
        self.r = r
    def area(self):
        print("Circle Area =", 3.14 * self.r * self.r)
class Rectangle(Shape):
    def __init__(self, l, b):
        self.l = l
        self.b = b
    def area(self):
        print("Rectangle Area =", self.l * self.b)
c = Circle(5)
c.area()
r = Rectangle(10, 4)
r.area()
